{
  "name": "secretaria-inteligente",
  "version": "1.0.0",
  "description": "Secretária Inteligente com IA - Atendimento WhatsApp, Agendamento e Cobrança",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "db:migrate": "node src/database/migrate.js",
    "db:seed": "node src/database/seed.js",
    "test": "jest --coverage",
    "lint": "eslint src/",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "docker:logs": "docker compose -f docker/docker-compose.yml logs -f"
  },
  "keywords": [
    "whatsapp",
    "ai",
    "secretary",
    "scheduling",
    "billing",
    "ollama",
    "gemma",
    "piper-tts",
    "groq"
  ],
  "author": "Felipe Lemes",
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "dotenv": "^16.4.5",
    "pg": "^8.13.0",
    "pg-pool": "^3.7.0",
    "ioredis": "^5.4.1",
    "bull": "^4.16.0",
    "node-cron": "^3.0.3",
    "axios": "^1.7.7",
    "form-data": "^4.0.0",
    "gray-matter": "^4.0.3",
    "glob": "^11.0.0",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.1.3",
    "uuid": "^10.0.0",
    "winston": "^3.14.2",
    "winston-daily-rotate-file": "^5.0.0",
    "express-rate-limit": "^7.4.0",
    "fluent-ffmpeg": "^2.1.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "jest": "^29.7.0",
    "eslint": "^9.9.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
